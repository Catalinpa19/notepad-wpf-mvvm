<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Notepad Clone"
        Height="650"
        Width="1100"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:HeaderToImageConverter x:Key="HeaderToImageConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileCommand}" />
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseFileCommand}" />
        <KeyBinding Command="ApplicationCommands.Find" Key="F" Modifiers="Control"/>
        <KeyBinding Command="ApplicationCommands.Replace" Key="H" Modifiers="Control"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New file"
                          InputGestureText="Ctrl+N"
                          Command="{Binding NewFileCommand}" />
                <MenuItem Header="Open file..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenFileCommand}" />
                <MenuItem Header="Save file"
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveFileCommand}" />
                <MenuItem Header="Save file as..."
                          Command="{Binding SaveAsFileCommand}" />
                <Separator/>
                <MenuItem Header="Close file"
                          InputGestureText="Ctrl+W"
                          Command="{Binding CloseFileCommand}" />
                <MenuItem Header="Close all files"
                          Command="{Binding CloseAllFilesCommand}" />
                <Separator/>
                <MenuItem Header="Exit"
                          Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="Search">
                <MenuItem Header="Find..."
                          InputGestureText="Ctrl+F"
                          Click="Find_Click"/>
                <MenuItem Header="Replace..."
                          InputGestureText="Ctrl+H"
                          Click="Replace_Click"/>
                <MenuItem Header="Replace All..."
                          Click="ReplaceAll_Click"/>
                <Separator/>
                <MenuItem Header="All tabs"
                          IsCheckable="True"
                          IsChecked="{Binding SearchInAllTabs}"
                          Command="{Binding SetAllTabsScopeCommand}"/>
                <MenuItem Header="Selected tab"
                          IsCheckable="True"
                          IsChecked="{Binding SearchInSelectedTab}"
                          Command="{Binding SetSelectedTabScopeCommand}"/>
            </MenuItem>

            <MenuItem Header="View">
                <MenuItem Header="Standard"
                          IsCheckable="True"
                          IsChecked="{Binding IsStandardView}"
                          Command="{Binding ShowStandardViewCommand}" />
                <MenuItem Header="Folder Explorer"
                          IsCheckable="True"
                          IsChecked="{Binding IsFolderExplorerVisible}"
                          Command="{Binding ShowFolderExplorerCommand}" />
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="New" Command="{Binding NewFileCommand}" />
                <Button Content="Open" Command="{Binding OpenFileCommand}" />
                <Button Content="Save" Command="{Binding SaveFileCommand}" />
                <Button Content="Close" Command="{Binding CloseFileCommand}" />
                <Separator/>
                <Button Content="Find" Click="Find_Click" />
                <Button Content="Replace" Click="Replace_Click" />
            </ToolBar>
        </ToolBarTray>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsFolderExplorerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <TreeView x:Name="FolderView"
                          ItemsSource="{Binding DirectoryItems}">
                    <TreeView.Resources>

                        <HierarchicalDataTemplate DataType="{x:Type local:DirectoryItemViewModel}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="New file"
                                                  Command="{Binding DataContext.NewFileInFolderCommand, Source={x:Reference FolderView}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Copy path"
                                                  Command="{Binding DataContext.CopyPathCommand, Source={x:Reference FolderView}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Copy folder"
                                                  Command="{Binding DataContext.CopyFolderCommand, Source={x:Reference FolderView}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Paste folder"
                                                  Command="{Binding DataContext.PasteFolderCommand, Source={x:Reference FolderView}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>

                                <Image Width="16"
                                       Height="16"
                                       Margin="0,0,6,0"
                                       Source="{Binding Type, Converter={StaticResource HeaderToImageConverter}}" />

                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <Style TargetType="{x:Type TreeViewItem}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <TabControl Grid.Column="1"
                        ItemsSource="{Binding Documents}"
                        SelectedItem="{Binding SelectedDocument}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayTitle}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 FontSize="14"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>